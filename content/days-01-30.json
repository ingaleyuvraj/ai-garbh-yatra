  "disclaimer": "ही माहिती सर्वसाधारण आहे. कृपया तुमच्या डॉक्टरांचा सल्ला घ्या.",
  "days": [
    {
      "id": "day_t1_001", "stage": "t1", "dayIndex": 1, "titleMr": "दिवस १", "disclaimerMr": "ही माहिती सर्वसाधारण आहे. कृपया तुमच्या डॉक्टरांचा सल्ला घ्या.",
      "slots": {
        "affirmation": { "id": "aff_t1_001", "type": "affirmation", "stage": "t1", "lang": "mr", "bodyMr": "मी शांत आहे, आणि माझ्या आत एक सुंदर सुरुवात होत आहे." },
        "garbhSamvad": { "id": "gs_t1_001", "type": "garbh_samvad", "stage": "t1", "lang": "mr", "titleMr": "स्वागत", "audioDurationSec": 180, "bodyMr": "माझ्या बाळा, तू आमच्या आयुष्यात येणार आहेस याचा आम्हाला मनापासून आनंद आहे. तू सुरक्षित आहेस." },
        "meditation": { "id": "med_t1_001", "type": "meditation", "stage": "t1", "lang": "mr", "audioDurationSec": 180, "bodyMr": "हळू श्वास घ्या, ४ मोजा, हळू सोडा. खांदे सैल करा.", "tags": ["breathing"] },
        "tip": { "id": "tip_t1_001", "type": "tip", "stage": "t1", "lang": "mr", "bodyMr": "दिवसभर थोडं थोडं पाणी प्या. घाई न करता विश्रांती घ्या.", "tags": ["hydration", "rest"] },
        "partnerTask": { "id": "pt_001", "type": "partner_task", "stage": "t1", "lang": "mr", "bodyMr": "आज आईला एक प्रेमळ शब्द सांगा आणि एक ग्लास पाणी द्या." }
      },
      "routine": [
        { "taskKey": "rt_breathe", "titleMr": "सकाळचे श्वसन", "deepLink": "app://calm/breathing" },
