    {
      "id": "day_t1_002", "stage": "t1", "dayIndex": 2, "titleMr": "दिवस २", "disclaimerMr": "ही माहिती सर्वसाधारण आहे. कृपया तुमच्या डॉक्टरांचा सल्ला घ्या.",
      "slots": {
        "affirmation": { "id": "aff_t1_002", "type": "affirmation", "stage": "t1", "lang": "mr", "bodyMr": "माझं शरीर शहाणं आहे; ते बाळासाठी योग्य ते करत आहे." },
        "garbhSamvad": { "id": "gs_t1_002", "type": "garbh_samvad", "stage": "t1", "lang": "mr", "titleMr": "गुणगुणणे", "audioDurationSec": 180, "bodyMr": "बाळा, आज मी तुझ्यासाठी एक शांत गाणं गुणगुणते. तुला ते आवडेल." },
        "meditation": { "id": "med_t1_002", "type": "meditation", "stage": "t1", "lang": "mr", "audioDurationSec": 240, "bodyMr": "डोळे मिटून शरीर पायांपासून डोक्यापर्यंत सैल करा.", "tags": ["relaxation"] },
        "tip": { "id": "tip_t1_002", "type": "tip", "stage": "t1", "lang": "mr", "bodyMr": "ताजी फळं आणि घरचं हलकं जेवण घ्या. आहाराबद्दल डॉक्टर/आहारतज्ञांचा सल्ला घ्या.", "tags": ["diet"] },
        "partnerTask": { "id": "pt_002", "type": "partner_task", "stage": "t1", "lang": "mr", "bodyMr": "आज स्वयंपाकात किंवा एखाद्या कामात मदत करा." }
      },
      "routine": [
