    {
      "id": "day_t1_003", "stage": "t1", "dayIndex": 3, "titleMr": "दिवस ३", "disclaimerMr": "ही माहिती सर्वसाधारण आहे. कृपया तुमच्या डॉक्टरांचा सल्ला घ्या.",
      "slots": {
        "affirmation": { "id": "aff_t1_003", "type": "affirmation", "stage": "t1", "lang": "mr", "bodyMr": "प्रत्येक श्वासासोबत मी अधिक शांत होत आहे." },
        "garbhSamvad": { "id": "gs_t1_003", "type": "garbh_samvad", "stage": "t1", "lang": "mr", "titleMr": "प्रेम", "audioDurationSec": 180, "bodyMr": "बाळा, तुझ्या येण्याची आम्ही आतुरतेने वाट पाहत आहोत. आम्ही तुझ्यावर खूप प्रेम करतो." },
        "meditation": { "id": "med_t1_003", "type": "meditation", "stage": "t1", "lang": "mr", "audioDurationSec": 180, "bodyMr": "श्वासावर लक्ष — विचार आले तरी हळूच श्वासाकडे परत या.", "tags": ["breathing"] },
        "tip": { "id": "tip_t1_003", "type": "tip", "stage": "t1", "lang": "mr", "bodyMr": "थकवा वाटला तर थांबा आणि विश्रांती घ्या. स्वतःशी प्रेमळ राहा.", "tags": ["rest"] },
        "partnerTask": { "id": "pt_003", "type": "partner_task", "stage": "t1", "lang": "mr", "bodyMr": "आज आईला आवडतं शांत संगीत लावा." }
      },
