        "garbhSamvad": { "id": "gs_t1_004", "type": "garbh_samvad", "stage": "t1", "lang": "mr", "titleMr": "ओळख", "audioDurationSec": 180, "bodyMr": "बाळा, आजचा दिवस छान आहे. मी तुझ्याशी थोडं बोलते म्हणजे आपली ओळख वाढेल." },
        "meditation": { "id": "med_t1_004", "type": "meditation", "stage": "t1", "lang": "mr", "audioDurationSec": 300, "bodyMr": "कमळासारखं मन हळू उमलू द्या; शांत राहा.", "tags": ["meditation"] },
        "tip": { "id": "tip_t1_004", "type": "tip", "stage": "t1", "lang": "mr", "bodyMr": "स्क्रीनपासून थोडा वेळ दूर राहा; मोकळी हवा घ्या.", "tags": ["wellbeing"] },
        "partnerTask": { "id": "pt_004", "type": "partner_task", "stage": "t1", "lang": "mr", "bodyMr": "आज दोघं मिळून १० मिनिटं शांत बसा." }
