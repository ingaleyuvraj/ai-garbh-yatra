        "meditation": { "id": "med_t1_006", "type": "meditation", "stage": "t1", "lang": "mr", "audioDurationSec": 240, "bodyMr": "मन अस्वस्थ असेल तर फक्त श्वास मोजा.", "tags": ["breathing"] },
